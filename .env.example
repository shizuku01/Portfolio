# Copy this file to ".env" (which is gitignored) and fill in real values.
# On the server:   cp .env.example .env   then edit .env
#
# Docker Compose automatically loads ".env" from the project directory.

# 16-character Gmail App Password used by the contact form to send email.
# Generate one at: https://myaccount.google.com/apppasswords
# Leave blank if you are not using the contact form yet.
EMAIL_PASSWORD=
